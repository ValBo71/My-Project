  "item": [
    {
      "name": "CreateUser",
      "item": [
        {
          "name": "Create Users",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"nameUser\", pm.variables.replaceIn('{{$randomFirstName}}'));\r",
                  "pm.collectionVariables.set(\"firstName\", pm.variables.replaceIn('{{$randomFirstName}}'));\r",
                  "pm.collectionVariables.set(\"lastName\", pm.variables.replaceIn('{{$randomFirstName}}'));\r",
                  "pm.collectionVariables.set(\"emailUser\", pm.variables.replaceIn('{{$randomEmail}}'));\r",
                  "pm.collectionVariables.set(\"pass\", pm.variables.replaceIn('{{$randomFirstName}}'));\r",
                  "pm.collectionVariables.set(\"phone\", pm.variables.replaceIn('{{$randomPhoneNumber}}'));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "pm.collectionVariables.set(\"userID\", pm.response.json().message);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "  {\r\n    \"username\": \"{{nameUser}}\",\r\n    \"firstName\": \"{{firstName}}\",\r\n    \"lastName\": \"{{lastName}}\",\r\n    \"email\": \"{{emailUser}}\",\r\n    \"password\": \"{{pass}}\",\r\n    \"phone\": \"{{phone}}\"\r\n  }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/v2/user",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "v2",
                "user"
              ],
              "query": [
                {
                  "key": "baseURL",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User created with supplited name\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expedtedLoginName = pm.collectionVariables.get(\"nameUser\");\r",
                  "    pm.expect(jsonData.username).to.eql(expedtedLoginName);\r",
                  "});\r",
                  "pm.test(\"User created with supplited first name\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expedtedFirstName = pm.collectionVariables.get(\"firstName\");\r",
                  "    pm.expect(jsonData.firstName).to.eql(expedtedFirstName);\r",
                  "});\r",
                  "pm.test(\"User created with supplited first Email\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expedteEmail = pm.collectionVariables.get(\"emailUser\");\r",
                  "    pm.expect(jsonData.email).to.eql(expedteEmail);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User ID check\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var expedtedID = pm.collectionVariables.get(\"userID\");\r",
                  "    pm.expect(jsonData.email).to.eql(expedtedID);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.collectionVariables.unset(\"pass\");\r",
                  "pm.collectionVariables.unset(\"phone\");\r",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseURL}}/v2/user/{{nameUser}}",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "v2",
                "user",
                "{{nameUser}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"pass\", pm.variables.replaceIn('{{$randomFirstName}}'));\r",
                  "pm.collectionVariables.set(\"phone\", pm.variables.replaceIn('{{$randomPhoneNumber}}'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
